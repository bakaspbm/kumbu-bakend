# =============================================================================
# Kumbu Backend — beta com API no PC + site na Vercel
# Copiar para .env na pasta Kumbu_bakend
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# --- Segredos (OBRIGATÓRIO preencher) ---
POSTGRES_DB=kumbu
POSTGRES_USER=kumbu
POSTGRES_PASSWORD=

KUMBU_JWT_SECRET=
KUMBU_ADMIN_EMAIL=admin@kumbu-market.com
KUMBU_ADMIN_PASSWORD=

# --- CORS: domínio Vercel + custom (sem localhost) ---
KUMBU_CORS_ORIGINS=https://kumbu-market.com,https://www.kumbu-market.com,https://admin.kumbu-market.com
# Previews Vercel (deploy de PRs)
KUMBU_CORS_ORIGIN_PATTERNS=https://*.vercel.app

KUMBU_PUBLIC_URL=https://kumbu-market.com

# URLs públicas da API (Cloudflare Tunnel)
KUMBU_STORAGE_URL=https://api.kumbu-market.com/files

# --- Docker Compose (postgres + redis + api) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/kumbu
SPRING_DATASOURCE_USERNAME=kumbu
SPRING_DATASOURCE_PASSWORD=

REDIS_HOST=redis
KUMBU_CACHE_REDIS_ENABLED=true
KUMBU_CACHE_TYPE=redis

# Mail/SMS desactivados no beta inicial (opcional)
KUMBU_MAIL_ENABLED=false
KUMBU_SMS_PROVIDER=log
KUMBU_FACEBOOK_TRUST_CLIENT_PROFILE=false

# OAuth — preencher quando configurar Google/Facebook
KUMBU_GOOGLE_CLIENT_ID=
KUMBU_GOOGLE_CLIENT_SECRET=
KUMBU_FACEBOOK_APP_ID=
KUMBU_FACEBOOK_APP_SECRET=

# Monitorização (opcional)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=beta-pc

# --- Se correr API com mvn spring-boot:run (sem container api) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kumbu
# REDIS_HOST=localhost
# KUMBU_CACHE_REDIS_ENABLED=false
# KUMBU_CACHE_TYPE=simple
