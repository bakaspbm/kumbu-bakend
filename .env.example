# =============================================================================
# Kumbu Backend — variáveis de ambiente (copiar para .env ou application-local.yml)
# =============================================================================

SPRING_PROFILES_ACTIVE=dev
KUMBU_JWT_SECRET=change-me-in-production-use-at-least-256-bits-secret-key-here

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kumbu_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

KUMBU_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
KUMBU_PUBLIC_URL=http://localhost:3000

# Email (opcional em dev — links aparecem nos logs)
KUMBU_MAIL_ENABLED=false
KUMBU_MAIL_FROM=noreply@kumbu.app
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# SMS OTP — log (dev) | twilio | africastalking
KUMBU_SMS_PROVIDER=log

# Twilio (internacional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Africa's Talking (recomendado para Angola)
# KUMBU_SMS_PROVIDER=africastalking
# AFRICASTALKING_USERNAME=sandbox
# AFRICASTALKING_API_KEY=
# AFRICASTALKING_FROM=KUMBU

# OAuth — credenciais sensíveis (NUNCA no frontend / NEXT_PUBLIC_*)
KUMBU_GOOGLE_CLIENT_ID=
KUMBU_GOOGLE_CLIENT_SECRET=
KUMBU_FACEBOOK_APP_ID=
KUMBU_FACEBOOK_APP_SECRET=
# Dev/rede restrita: aceita perfil validado no browser se Google/Facebook API falhar
KUMBU_FACEBOOK_TRUST_CLIENT_PROFILE=false

# Armazenamento
KUMBU_STORAGE_PATH=./uploads
KUMBU_STORAGE_PRIVATE_PATH=./private-uploads
KUMBU_STORAGE_URL=http://localhost:8080/files
